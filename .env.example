# --- Google Maps (two keys required) ---
# Server key: Search tab + /api/search + Places API (NO HTTP referrer restriction)
GOOGLE_PLACES_API_KEY=
# Browser key: Map tab + Maps JavaScript (HTTP referrer: leadradar.us + localhost)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# See GOOGLE_MAPS_SETUP.md for Google Cloud Console steps.

ANTHROPIC_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# For local migrations: Supabase → Project Settings → Database → Connection string (URI, pooler)
SUPABASE_DB_URL=
RESEND_FROM_EMAIL=onboarding@resend.dev
# Canonical app URL (Stripe redirects, emails). APP_BASE_URL is kept as a server fallback.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=https://www.leadradar.us

# Stripe (test keys — create products/prices in Stripe Dashboard first)
STRIPE_SECRET_KEY=sk_test_REMPLACE_MOI
STRIPE_WEBHOOK_SECRET=whsec_REMPLACE_MOI
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACE_MOI
STRIPE_PRICE_PRO_MONTHLY=price_REMPLACE_MOI
STRIPE_PRICE_PRO_YEARLY=price_REMPLACE_MOI
